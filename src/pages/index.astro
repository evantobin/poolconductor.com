---
import BaseLayout from "../layouts/BaseLayout.astro";

const controllerRepository = "https://github.com/evantobin/matter-pool-controller";
---

<BaseLayout>
  <header class="site-header">
    <a class="wordmark" href="/" aria-label="Pool Conductor home">Pool Conductor</a>
    <div class="header-actions">
      <nav aria-label="Primary navigation">
        <a href="#features">Features</a>
        <a href="#local">Local control</a>
        <a href="#availability">Availability</a>
      </nav>
      <a class="login-link" href="https://my.poolconductor.com">Log in</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <p class="eyebrow">Matter pool control</p>
      <h1>Pool equipment that feels at home in your home.</h1>
      <p class="hero-summary">
        Pool Conductor brings a variable-speed pump, relay-connected equipment,
        and optional sensors into Apple Home and other Matter platforms.
      </p>
      <div class="hero-actions">
        <a class="button" href="#availability">Get Pool Conductor</a>
        <a class="text-link" href={controllerRepository}>Build it yourself</a>
      </div>
    </section>

    <section class="summary-band" aria-label="Product summary">
      <span>Variable-speed pump control</span>
      <span>Six relay channels</span>
      <span>Optional water, flow, and temperature inputs</span>
    </section>

    <section class="content-section" id="features">
      <div class="section-heading">
        <p class="eyebrow">The essentials</p>
        <h2>Useful control, without another app.</h2>
      </div>
      <div class="feature-list">
        <article>
          <h3>Pump speed</h3>
          <p>Set a target speed from a familiar Matter dimmer. The controller keeps the pump at its requested RPM locally.</p>
        </article>
        <article>
          <h3>Equipment relays</h3>
          <p>Expose lights, cleaners, valves, and other supported equipment as separate switches in your smart home.</p>
        </article>
        <article>
          <h3>Pool conditions</h3>
          <p>Add compatible inputs for water level, flow, and temperature when those signals are useful to your setup.</p>
        </article>
      </div>
    </section>

    <section class="content-section local-section" id="local">
      <div class="section-heading">
        <p class="eyebrow">Local first</p>
        <h2>Made to stay on your network.</h2>
      </div>
      <div class="local-copy">
        <p>
          Pool Conductor is a Matter bridge. Commands move between the
          controller and your home locally, with no required cloud account or
          subscription.
        </p>
        <ul>
          <li>Works with local Matter automations</li>
          <li>No required recurring service</li>
          <li>Physical reset for a clean ownership handoff</li>
        </ul>
      </div>
    </section>

    <section class="content-section open-source">
      <div class="section-heading">
        <p class="eyebrow">Open-source firmware</p>
        <h2>Prefer to bring your own hardware?</h2>
      </div>
      <div class="local-copy">
        <p>
          The ESP32-S3 controller firmware is available for people who want to
          build, wire, and customize their own installation.
        </p>
        <a class="text-link" href={controllerRepository}>View the controller code</a>
      </div>
    </section>

    <section class="availability" id="availability">
      <p class="eyebrow">Pool Conductor</p>
      <h2>Finished controller availability is coming soon.</h2>
      <p>Follow the open-source project for release updates and product availability.</p>
      <a class="button" href={controllerRepository}>Follow the project</a>
    </section>
  </main>

  <footer>
    <span class="wordmark">Pool Conductor</span>
    <a href={controllerRepository}>Open-source controller</a>
  </footer>
</BaseLayout>
