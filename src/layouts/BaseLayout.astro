---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pool Conductor | Bring Your Pool Into Matter",
  description = "A local-first Matter controller for the pool equipment you already own."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#dff6f7" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><path fill=%22%231b9bb4%22 d=%22M16 3c5 6 9 10 9 16a9 9 0 1 1-18 0c0-6 4-10 9-16Z%22/></svg>" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
