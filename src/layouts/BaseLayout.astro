---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pool Conductor | Bring Your Pool Into Matter",
  description = "A local-first Matter controller for the pool equipment you already own."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#e7f2f2" />
    <link rel="icon" type="image/svg+xml" href="/brand/pool-conductor-mark.svg" />
    <link rel="mask-icon" href="/brand/pool-conductor-mark.svg" color="#1d2a2b" />
    <title>{title}</title>
    <script type="importmap">
      {
        "imports": {
          "three": "https://unpkg.com/three@0.174.0/build/three.module.js",
          "three/addons/": "https://unpkg.com/three@0.174.0/examples/jsm/"
        }
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
